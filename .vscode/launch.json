{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flask",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "run.py",
                "FLASK_DEBUG": "1"
            },
            "args": ["run", "--no-debugger"],
            "jinja": true,
            "cwd": "${workspaceFolder}"
        }
    ]
}